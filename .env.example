# =============================
# Stock.AI 環境變數設定
# =============================

# Google Gemini API Key（必填，完全免費）
# 取得方式：https://aistudio.google.com/app/apikey
# 登入 Google 帳號 → 點 "Get API Key" → 建立 → 複製
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini 模型選擇（選填）
# gemini-1.5-flash  → 免費、快速（推薦）
# gemini-1.5-pro    → 更強但有用量限制
# gemini-2.0-flash  → 最新免費模型
GEMINI_MODEL=gemini-1.5-flash
